{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMCP",
  "version": "0.1.0",
  "identifier": "com.hyperdev.amcp",
  "build": {
    "beforeDevCommand": "../../scripts/build-desktop-sidecars.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && ../../scripts/build-desktop-sidecars.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "AMCP — Agent Memory Control Plane", "width": 1440, "height": 920, "minWidth": 1100, "minHeight": 720 }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/amcp-agent",
      "binaries/amcp-controller",
      "binaries/amcp-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
