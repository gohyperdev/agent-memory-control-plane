{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMCP",
  "version": "0.1.0",
  "identifier": "com.hyperdev.amcp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "AMCP — Agent Memory Control Plane", "width": 1440, "height": 920, "minWidth": 1100, "minHeight": 720 }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
